    display: inline-block;
}
.jump-link a {
    background: #333;
    color: #fff;
    padding: 8px 15px;
    text-decoration: none;
    border-radius: 20px;
    font-size: 13px;
    transition: all 0.3s;
}
.jump-link a:hover {
    background: #007bff;
    box-shadow: 0 5px 10px rgba(0,123,255,0.3);
}
/* CSS Recent Posts Keren Dibawah Postingan */
.popular-posts-snippet {
    margin: 20px 0;
    padding: 10px 0;
    border-top: 2px solid #eee;
}
.popular-posts-title {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 15px;
}
.popular-posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 15px;
}
.popular-posts-item {
    text-align: center;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
}
.popular-posts-item:hover {
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transform: translateY(-3px);
}
.popular-posts-thumbnail {
    width: 100%;
    height: 100px;
    object-fit: cover;
}
.popular-posts-title-link {
    font-size: 14px;
    font-weight: 500;
    color: #333;
    display: block;
    padding: 10px;
    text-decoration: none;
    line-height: 1.3;
}
.popular-posts-title-link:hover {
    color: #008cba;
}

/* Responsive --------------------- */
@media screen and (max-width: 525px){#related_posts li{width:50%;}}
@media screen and (max-width: 700px) and (min-width: 525px){#related_posts li{width:33.3%;}}
@media screen and (max-width: 900px) and (min-width: 701px){#related_posts li{width:25%;}}
@media screen and (max-width: 1170px) and (min-width: 901px){#related_posts li{width:20%;}}
@media screen and (max-width: 1351px) and (min-width: 1171px){#related_posts li{width:16.66%;}}

.post-body {
  font-family: 'Open Sans', sans-serif;
  font-size: 16px;
  line-height: 1.8;
  color: #333;
}
.post-body h2, .post-body h3 {
  color: #2c3e50;
  margin-top: 25px;
  margin-bottom: 15px;
}
.post-body blockquote {
  background: #f9f9f9;
  border-left: 5px solid #008c5f;
  margin: 1.5em 10px;
  padding: 1em;
  font-style: italic;
  color: #555;
}
table {
  border-collapse: collapse;
  width: 100%;
  margin: 1rem 0;
}
th {
  background-color: #008c5f;
  color: white;
  padding: 12px;
}
td {
  padding: 10px;
  border: 1px solid #ddd;
}
tr:nth-child(even) {
  background-color: #f2f2f2;
}
/* Container Utama */
.recent-post-container {
    margin: 30px 0;
    padding: 20px;
    background-color: #f9f9f9;
    border-radius: 10px;
    font-family: sans-serif;
}

.recent-post-title {
    text-align: center;
    font-size: 24px;
    margin-bottom: 20px;
    color: #333;
}

/* Grid Layout */
.recent-post-grid {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
}

/* Styling Card */
.post-card {
    background: white;
    flex: 1 1 calc(33.333% - 20px); /* 3 kartu per baris */
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
}

.post-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 12px rgba(0,0,0,0.15);
}

.post-img {
    width: 100%;
    height: 150px;
    object-fit: cover;
}

.post-content {
    padding: 15px;
}

.post-content h3 {
    font-size: 16px;
    margin: 0 0 10px 0;
    line-height: 1.4;
    color: #222;
}

.post-date {
    font-size: 12px;
    color: #888;
}

/* Responsif untuk Mobile */
@media screen and (max-width: 768px) {
    .post-card {
        flex: 1 1 calc(50% - 20px); /* 2 kartu per baris */
    }
}

@media screen and (max-width: 480px) {
    .post-card {
        flex: 1 1 100%; /* 1 kartu per baris */
    }
}

.post-title, .entry-title {
    background: linear-gradient(to right, #ffedcc 0%, #ffffff 100%);
    padding: 10px;
    border-radius: 5px;
    font-family: 'Helvetica Neue', sans-serif;
    color: #e67e22;
}
.post-title, .entry-title {
    font-family: 'Poppins', sans-serif; /* Pastikan font dimuat */
    font-weight: 700;
    font-size: 32px;
    color: #2c3e50;
    text-transform: capitalize;
    letter-spacing: -1px;
    border-left: 5px solid #3498db; /* Garis kiri */
    padding-left: 15px;
    line-height: 1.2;
}
.post-title, .entry-title {
    font-family: 'Poppins', sans-serif; /* Pastikan font dimuat */
    font-weight: 700;
    font-size: 32px;
    color: #2c3e50;
    text-transform: capitalize;
    letter-spacing: -1px;
    border-left: 5px solid #3498db; /* Garis kiri */
    padding-left: 15px;
    line-height: 1.2;
}

/* Styling untuk judul postingan dengan border minimalis */
.post-title a {
  position: relative;
  display: inline-block;
  color: #1a1a1a;
  font-weight: 700;
  text-decoration: none;
  letter-spacing: -0.5px;
  padding: 10px 16px;
  border: 2px solid #667eea;
  border-radius: 8px;
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  background: transparent;
}

/* Background gradient muncul saat hover */
.post-title a::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(120deg, #667eea 0%, #764ba2 100%);
  border-radius: 6px;
  opacity: 0;
  z-index: -1;
  transition: opacity 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* Efek saat judul di-hover */
.post-title a:hover {
  text-decoration: none;
  border-color: transparent;
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(102, 126, 234, 0.35);
}

.post-title a:hover::before {
  opacity: 1;
  z-index: -1;
}
.container-foto {
  position: relative;
  width: 100%;
  max-width: 400px;
  overflow: hidden;
  border-radius: 10px;
}

.container-foto img {
  width: 100%;
  height: auto;
  transition: transform 0.5s ease;
}

.container-foto:hover img {
  transform: scale(1.1); /* Zoom */
}

.overlay {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.5); /* Warna overlay */
  opacity: 0;
  transition: opacity 0.5s ease;
  display: flex;
  justify-content: center;
  align-items: center;
}

.container-foto:hover .overlay {
  opacity: 1; /* Munculkan overlay */
}

.text {
  color: white;
  font-size: 20px;
  font-family: sans-serif;
}
.polaroid {
  background-color: white;
  padding: 15px 15px 30px 15px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.2);
  width: 250px;
  text-align: center;
  transform: rotate(-3deg); /* Rotasi sedikit */
  transition: transform 0.3s;
}

.polaroid:hover {
  transform: rotate(0deg) scale(1.05); /* Lurus saat di-hover */
}

.polaroid img {
  width: 100%;
  height: auto;
}

.caption {
  margin-top: 10px;
  font-family: 'Courier New', monospace;
  color: #333;
}
.efek-bw {
  filter: grayscale(100%);
  transition: filter 0.5s ease;
  border-radius: 8px;
}

.efek-bw:hover {
  filter: grayscale(0%);
}
.foto-bayangan {
  width: 300px;
  border-radius: 15px;
  box-shadow: 0 10px 20px rgba(0,0,0,0.19), 0 6px 6px rgba(0,0,0,0.23);
  transition: box-shadow 0.3s ease-in-out;
}

.foto-bayangan:hover {
  box-shadow: 0 19px 38px rgba(0,0,0,0.30), 0 15px 12px rgba(0,0,0,0.22);
}


