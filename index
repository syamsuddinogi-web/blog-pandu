    .vote-container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 20px;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  border-radius: 16px;
  margin: 20px 0;
  flex-wrap: wrap;
}
.vote-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.3s ease;
  border: none;
  font-weight: 600;
  font-size: 14px;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.vote-btn svg {
  transition: transform 0.3s ease;
}
.vote-btn:hover svg {
  transform: scale(1.15);
}
.like-btn {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  color: #2e7d32;
}
.like-btn:hover {
  background: linear-gradient(135deg, #c8e6c9 0%, #a5d6a7 100%);
  box-shadow: 0 4px 15px rgba(46, 125, 50, 0.3);
  transform: translateY(-2px);
}
.like-btn.active {
  background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
  color: white;
}
.dislike-btn {
  background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
  color: #c62828;
}
.dislike-btn:hover {
  background: linear-gradient(135deg, #ffcdd2 0%, #ef9a9a 100%);
  box-shadow: 0 4px 15px rgba(198, 40, 40, 0.3);
  transform: translateY(-2px);
}
.dislike-btn.active {
  background: linear-gradient(135deg, #ef5350 0%, #c62828 100%);
  color: white;
}
.vote-feedback {
  width: 100%;
  text-align: center;
  margin-top: 12px;
  font-size: 14px;
  font-weight: 500;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.vote-feedback.show {
  opacity: 1;
} 

/* Mengubah Tampilan Judul Postingan */
.post-title {
  font-family: 'Arial', sans-serif;
  color: #333333;
  font-size: 28px;
  text-align: center;
}

/* Mengubah Font dan Ukuran Postingan */
.post-body {
  font-family: 'Lora', serif;
  font-size: 16px;
  line-height: 1.8;
  color: #444444;
}

/* Memberi Bingkai/Padding pada Postingan */
.post-outer {
  background-color: #ffffff;
  padding: 20px;
  border: 1px solid #eeeeee;
  border-radius: 8px;
}

/* Mengatur Gambar Postingan Agar Responsif */
.post-body img {
  max-width: 100%;
  height: auto;
  border-radius: 5px;
}
.post-outer {
    background: #fff; /* Warna latar belakang kartu */
    border-radius: 15px; /* Sudut tumpul */
    box-shadow: 0 4px 15px rgba(0,0,0,0.1); /* Efek bayangan halus */
    padding: 20px;
    margin-bottom: 30px; /* Jarak antar postingan */
    transition: all 0.3s ease; /* Animasi transisi */
    border: 1px solid #eee;
}

/* Efek saat kursor diarahkan ke postingan */
.post-outer:hover {
    transform: translateY(-5px); /* Mengangkat kartu */
    box-shadow: 0 8px 25px rgba(0,0,0,0.15); /* Bayangan lebih dalam */
}
.post-title a {
    font-family: 'Poppins', sans-serif; /* Pastikan font dimuat */
    font-weight: 700;
    color: #2c3e50;
    text-decoration: none;
    transition: color 0.2s;
    border-bottom: 3px solid #3498db; /* Garis bawah unik */
    padding-bottom: 5px;
}

.post-title a:hover {
    color: #3498db;
}
.post-body img, .post-thumbnail {
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    transition: transform 0.3s ease;
}

.post-body img:hover {
    transform: scale(1.02); /* Sedikit membesar saat dihover */
}
.jump-link a {
    background: linear-gradient(45deg, #ff416c, #ff4b2b); /* Warna gradient */
    color: white;
    padding: 10px 20px;
    border-radius: 25px;
    text-decoration: none;
    font-weight: bold;
    display: inline-block;
    transition: background 0.3s;
}

.jump-link a:hover {
    background: linear-gradient(45deg, #ff4b2b, #ff416c);
    box-shadow: 0 4px 10px rgba(255, 75, 43, 0.3);
}
/* CSS Popup Pojok */
.popup-corner {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 300px;
  background: white;
  border-radius: 10px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.3);
  padding: 20px;
  z-index: 9999;
  display: none; /* Awalnya disembunyikan */
  animation: slideIn 0.5s ease-out;
}
@keyframes slideIn {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}
.close-corner {
  position: absolute;
  top: 5px;
  right: 10px;
  cursor: pointer;
  font-weight: bold;
}

.post-title, .entry-title {
    background: linear-gradient(to right, #ffedcc 0%, #ffffff 100%);
    padding: 10px;
    border-radius: 5px;
    font-family: 'Helvetica Neue', sans-serif;
    color: #e67e22;
}
.post-title, .entry-title {
    font-family: 'Poppins', sans-serif; /* Pastikan font dimuat */
    font-weight: 700;
    font-size: 32px;
    color: #2c3e50;
    text-transform: capitalize;
    letter-spacing: -1px;
    border-left: 5px solid #3498db; /* Garis kiri */
    padding-left: 15px;
    line-height: 1.2;
}
.post-title, .entry-title {
    font-family: 'Poppins', sans-serif; /* Pastikan font dimuat */
    font-weight: 700;
    font-size: 32px;
    color: #2c3e50;
    text-transform: capitalize;
    letter-spacing: -1px;
    border-left: 5px solid #FF9900; /* Garis kiri */
    padding-left: 15px;
    line-height: 1.2;
}

.share-container {
  position: fixed;
  bottom: 20px;
  left: 20px;
  display: flex;
  flex-direction: column-reverse;
  align-items: center;
  z-index: 1000;
}

.share-toggle { display: none; }

.share-button {
  background: linear-gradient(45deg, #ff416c, #ff4b2b);
  color: white;
  padding: 12px 20px;
  border-radius: 50px;
  cursor: pointer;
  box-shadow: 0 4px 15px rgba(255, 75, 43, 0.4);
  transition: 0.3s;
  font-weight: bold;
  display: flex;
  align-items: center;
  gap: 8px;
}

.social-icons {
  display: flex;
  flex-direction: column;
  gap: 10px;
  opacity: 0;
  visibility: hidden;
  transition: 0.3s;
  margin-bottom: 15px;
}

.share-toggle:checked ~ .social-icons {
  opacity: 1;
  visibility: visible;
}

