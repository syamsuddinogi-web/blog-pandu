#logo-container h1 {
  margin: 0;
  letter-spacing: 2px;
}
/* 1. Reset Dasar & Tipografi */
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    line-height: 1.7; /* Meningkatkan keterbacaan */
    color: #333;
    background-color: #f9f9f9;
    margin: 0;
    padding: 0;
}

/* 2. Container Postingan (Centering & Readability) */
.post-container {
    max-width: 800px; /* Lebar optimal untuk membaca */
    margin: 20px auto;
    padding: 30px;
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05); /* Efek modern */
}

/* 3. Judul Postingan */
.post-title {
    font-size: 2.5rem;
    line-height: 1.2;
    color: #1a1a1a;
    margin-bottom: 10px;
}

/* 4. Meta Data (Author, Date) */
.post-meta {
    font-size: 0.9rem;
    color: #777;
    margin-bottom: 20px;
    border-bottom: 1px solid #eee;
    padding-bottom: 15px;
}

/* 5. Gambar Utama */
.post-thumbnail img {
    width: 100%;
    height: auto;
    border-radius: 5px;
    margin-bottom: 25px;
}

/* 6. Styling Isi Konten (SEO Friendly) */
.post-content h2 {
    font-size: 1.8rem;
    color: #222;
    margin-top: 30px;
    border-left: 5px solid #007bff; /* Efek highlight */
    padding-left: 10px;
}

.post-content p {
    margin-bottom: 20px;
}

.post-content a {
    color: #007bff;
    text-decoration: none;
    transition: 0.3s;
}

.post-content a:hover {
    text-decoration: underline;
    color: #0056b3;
}

/* 7. Responsif (Mobile Friendly) */
@media (max-width: 600px) {
    .post-container {
        padding: 15px;
        margin: 10px;
    }
    .post-title {
        font-size: 1.8rem;
    }
}
.button-keren {
  background-color: #4CAF50; /* Warna dasar */
  color: white;
  padding: 15px 25px;
  text-decoration: none;
  border-radius: 30px; /* Sudut tumpul */
  transition: all 0.3s ease;
  box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  display: inline-block;
  font-family: Arial, sans-serif;
  font-weight: bold;
}

.button-keren:hover {
  background-color: #45a049;
  transform: translateY(-3px); /* Efek terangkat */
  box-shadow: 0 6px 12px rgba(0,0,0,0.2);
}
.card-post {
  background: #fff;
  border-radius: 10px;
  padding: 20px;
  transition: 0.4s;
  border: 1px solid #eee;
}

.card-post:hover {
  transform: scale(1.05); /* Sedikit membesar */
  box-shadow: 0 10px 20px rgba(0,0,0,0.1);
}
.judul-gradasi {
  font-size: 40px;
  font-weight: bold;
  background: linear-gradient(to right, #30cfd0 0%, #330867 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.bg-animasi {
  background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
  background-size: 400% 400%;
  animation: gradientBG 15s ease infinite;
}

@keyframes gradientBG {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
::-webkit-scrollbar {
  width: 10px;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
}

::-webkit-scrollbar-thumb {
  background: #888;
  border-radius: 5px;
}

::-webkit-scrollbar-thumb:hover {
  background: #555;
}
.button-cool {
    padding: 15px 30px;
    background-color: #007bff;
    color: white;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    font-weight: bold;
}

.button-cool:hover {
    background-color: #0056b3;
    box-shadow: 0 0 15px #007bff;
    transform: translateY(-3px);
}
.card-style {
    background: #fff;
    border-radius: 10px;
    padding: 20px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
}

.card-style:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
}
.gradient-text {
    font-size: 36px;
    font-weight: bold;
    background: linear-gradient(45deg, #f3ec78, #af4261);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
.floating-img {
    animation: float 3s ease-in-out infinite;
}

@keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
}
